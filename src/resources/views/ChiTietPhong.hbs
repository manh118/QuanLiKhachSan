{{!--  Vẽ lịch --}}
<script>
    // --- KHAI BÁO BIẾN TOÀN CỤC ---
    // Phải đặt các hằng số này ở ngoài để tất cả các hàm đều có thể truy cập
    const SURCHARGE_PER_EXTRA_ADULT = 100000;
    const ROOM_TYPE_MAX_ADULTS = {{ Room.roomType.maxAdults }};
    const ROOM_PRICE_PER_NIGHT = {{ Room.roomType.price }};
    // (Đảm bảo controller Chi_Tiet_Phong đã populate('roomType') 
    //  và roomType có trường maxAdults và price)


    // --- HÀM VẼ LỊCH ---
    function renderRoomCalendar(containerId, year, month, availability = []) {
        const container = document.getElementById(containerId);
        if (!container) return;
        const monthMoment = moment({ year: year, month: month - 1 });
        const daysInMonth = monthMoment.daysInMonth();
        const firstDayOfMonth = monthMoment.startOf('month').day();
        let calendarHTML = `<table class="table table-bordered table-calendar"><thead><tr>`;
        const weekdays = ['CN', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7'];
        weekdays.forEach(day => calendarHTML += `<th class="day-header"><small>${day}</small></th>`);
        calendarHTML += `</tr></thead><tbody><tr>`;
        for (let i = 0; i < firstDayOfMonth; i++) {
            calendarHTML += `<td class="empty-cell"></td>`;
        }
        let dayCounter = 1;
        for (let i = firstDayOfMonth; i < 7; i++) {
            if (dayCounter > daysInMonth) break;
            const dayData = availability.find(d => d.date === moment({ year: year, month: month - 1, date: dayCounter }).format('YYYY-MM-DD')) || { status: 'past' };
            const canClick = dayData.status === 'available';
            calendarHTML += `<td class="day-cell status-${dayData.status} ${canClick ? 'js-calendar-select-date' : ''}" data-date="${dayData.date}" title="${dayData.status === 'available' ? 'Chọn ngày ' + dayCounter : (dayData.status === 'booked' ? 'Đã đặt' : 'Quá khứ')}">${dayCounter}</td>`;
            dayCounter++;
        }
        calendarHTML += `</tr>`;
        while (dayCounter <= daysInMonth) {
            calendarHTML += `<tr>`;
            for (let i = 0; i < 7 && dayCounter <= daysInMonth; i++) {
                const dayData = availability.find(d => d.date === moment({ year: year, month: month - 1, date: dayCounter }).format('YYYY-MM-DD')) || { status: 'past' };
                const canClick = dayData.status === 'available';
                calendarHTML += `<td class="day-cell status-${dayData.status} ${canClick ? 'js-calendar-select-date' : ''}" data-date="${dayData.date}" title="${dayData.status === 'available' ? 'Chọn ngày ' + dayCounter : (dayData.status === 'booked' ? 'Đã đặt' : 'Quá khứ')}">${dayCounter}</td>`;
                dayCounter++;
            }
             if (dayCounter > daysInMonth) {
                const remainingCells = 7 - ( (firstDayOfMonth + daysInMonth) % 7 );
                 if(remainingCells < 7) {
                     for (let i = 0; i < remainingCells; i++) { calendarHTML += `<td class="empty-cell"></td>`; }
                 }
             }
            calendarHTML += `</tr>`;
        }
        calendarHTML += `</tbody></table>`;
        container.innerHTML = calendarHTML;
        addCalendarDateClickListeners(); // Gắn lại listener cho các ô mới
    }

    // --- HÀM XỬ LÝ CLICK VÀO NGÀY TRỐNG TRÊN LỊCH ---
    function handleDateClick() {
        const selectedDate = this.dataset.date;
        const roomBtn = document.querySelector('.js-show-room-calendar-modal'); // Lấy nút mở lịch
        const roomNumber = roomBtn.dataset.roomNumber;
        const roomId = roomBtn.dataset.roomId;
        const roomPrice = parseFloat(roomBtn.dataset.roomPrice) || 0;

        const bookingModal = document.querySelector('.js-modal__booking'); // Lấy modal đặt phòng
        if (bookingModal) {
            bookingModal.querySelector('#checkInDate').value = selectedDate;
            const nextDay = moment(selectedDate).add(1, 'day').format('YYYY-MM-DD');
            bookingModal.querySelector('#checkOutDate').value = nextDay;
            bookingModal.querySelector('#modalRoomName').textContent = `- Phòng ${roomNumber}`;
            bookingModal.querySelector('#roomId').value = roomId;
            bookingModal.dataset.roomPrice = roomPrice; // Gán giá phòng vào modal
            
            // Đặt về giá trị mặc định cho số lượng khách
            bookingModal.querySelector('#modalNguoiLon').value = 1;
            bookingModal.querySelector('#modalNguoiLonDisplay').textContent = 1;
            bookingModal.querySelector('#modalTreEm').value = 0;
            bookingModal.querySelector('#modalTreEmDisplay').textContent = 0;
            
            // Reset dịch vụ
            bookingModal.querySelectorAll('.modal__booking__service__input').forEach(input => {
                input.value = 0;
                const display = document.getElementById('display_' + input.id);
                if (display) display.textContent = 0;
            });

            bookingModal.classList.add('open');
            document.body.classList.add('no-scroll');
            $('#roomCalendarModal').modal('hide'); // Đóng modal lịch
        }
    }

    // --- HÀM GẮN EVENT LISTENER CHO Ô LỊCH ---
    function addCalendarDateClickListeners() {
        document.querySelectorAll('.js-calendar-select-date').forEach(cell => {
            cell.removeEventListener('click', handleDateClick);
            cell.addEventListener('click', handleDateClick);
        });
    }

    // --- LOGIC CHÍNH KHI TẢI TRANG (GỘP TẤT CẢ VÀO ĐÂY) ---
    document.addEventListener('DOMContentLoaded', function() {
        
        // === 1. XỬ LÝ MODAL LỊCH ===
        const showCalendarBtn = document.querySelector('.js-show-room-calendar-modal');
        const calendarModal = $('#roomCalendarModal');
        const calendarContainerId = 'room-calendar-container';
        const monthYearDisplay = calendarModal.find('.calendar-month-year');
        const prevMonthBtn = calendarModal.find('.js-prev-month');
        const nextMonthBtn = calendarModal.find('.js-next-month');

        let currentDisplayMonth;
        let currentRoomId;

        // Hàm gọi API và vẽ lịch
        async function loadAndRenderCalendar(roomId, monthMoment) {
            currentDisplayMonth = monthMoment.clone();
            currentRoomId = roomId;
            monthYearDisplay.text(monthMoment.format('MM/YYYY'));
            prevMonthBtn.data('month', monthMoment.clone().subtract(1, 'month').format('YYYY-MM'));
            nextMonthBtn.data('month', monthMoment.clone().add(1, 'month').format('YYYY-MM'));
            document.getElementById(calendarContainerId).innerHTML = '<p class="text-center">Đang tải lịch...</p>';
            try {
                // *** SỬA LẠI URL API ***
                const apiUrl = `/hangphong/api/rooms/${roomId}/availability?month=${monthMoment.format('YYYY-MM')}`;
                const response = await fetch(apiUrl);
                if (!response.ok) { throw new Error('Không thể tải dữ liệu lịch'); }
                const data = await response.json();
                renderRoomCalendar(calendarContainerId, monthMoment.year(), monthMoment.month() + 1, data.availability);
            } catch (error) {
                console.error(error);
                document.getElementById(calendarContainerId).innerHTML = '<p class="text-center text-danger">Lỗi tải lịch.</p>';
            }
        }

        // Gắn Event Listener cho nút "Xem Lịch & Đặt Phòng"
        if (showCalendarBtn) {
            showCalendarBtn.addEventListener('click', function() {
                const roomId = this.dataset.roomId;
                loadAndRenderCalendar(roomId, moment());
                calendarModal.modal('show');
            });
        }
        // Gắn Event Listener cho nút chuyển tháng
        prevMonthBtn.on('click', function() { loadAndRenderCalendar(currentRoomId, moment($(this).data('month'), 'YYYY-MM')); });
        nextMonthBtn.on('click', function() { loadAndRenderCalendar(currentRoomId, moment($(this).data('month'), 'YYYY-MM')); });


        // === 2. XỬ LÝ MODAL ĐẶT PHÒNG VÀ LOGIC GIÁ ===
        const modal = document.querySelector('.js-modal__booking');
        const modalClose = modal.querySelector('.modal__booking__close');
        const inputServices = modal.querySelectorAll('.modal__booking__service__input');
        const btnDat = modal.querySelector('.modal__booking__btn');
        
        // Config Limits
        const MAX_ADULTS_ALLOWED = ROOM_TYPE_MAX_ADULTS + 1;
        const MAX_CHILDREN_ALLOWED = 2;

        // Đóng modal
        modalClose.addEventListener('click', function() {
            modal.classList.remove('open');
            document.body.classList.remove('no-scroll');
        });
        
        // Xử lý nút tăng giảm (Nguời lớn / Trẻ em)
        modal.querySelectorAll('.js-qty-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const targetId = this.dataset.target;
                const action = this.dataset.action;
                const input = document.getElementById(targetId);
                const display = document.getElementById(targetId + 'Display');
                
                let val = parseInt(input.value, 10);
                if (isNaN(val)) val = (targetId === 'modalNguoiLon' ? 1 : 0);
                
                if (action === 'plus') {
                    if (targetId === 'modalNguoiLon' && val >= MAX_ADULTS_ALLOWED) {
                        alert(`Phòng này tối đa chỉ ở được ${MAX_ADULTS_ALLOWED} người lớn!`);
                        return;
                    }
                    if (targetId === 'modalTreEm' && val >= MAX_CHILDREN_ALLOWED) {
                        alert(`Phòng này tối đa chỉ thêm được ${MAX_CHILDREN_ALLOWED} trẻ em!`);
                        return;
                    }
                    val++;
                } else if (action === 'minus') {
                    const minVal = (targetId === 'modalNguoiLon' ? 1 : 0);
                    if (val > minVal) val--;
                }
                
                input.value = val;
                display.textContent = val;
                calculateTotal();
            });
        });

        // Xử lý nút tăng giảm (Dịch vụ)
        modal.querySelectorAll('.js-service-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const targetId = this.dataset.target;
                const action = this.dataset.action;
                const input = document.getElementById(targetId);
                const display = document.getElementById('display_' + targetId);
                
                let val = parseInt(input.value, 10) || 0;
                
                if (action === 'plus') val++;
                else if (action === 'minus' && val > 0) val--;
                
                input.value = val;
                display.textContent = val;
                calculateTotal();
            });
        });

        // Tự động tính tiền khi thay đổi ngày hoặc SĐT
        modal.querySelector('#checkInDate').addEventListener('change', calculateTotal);
        modal.querySelector('#checkOutDate').addEventListener('change', calculateTotal);
        modal.querySelector('#phone').addEventListener('input', function() {
            document.getElementById('noiDungCK').textContent = `DP ${this.value || '[Số điện thoại]'}`;
        });

        // Hàm tính toán Real-time
        async function calculateTotal() {
            const checkIn = new Date(document.getElementById('checkInDate').value);
            const checkOut = new Date(document.getElementById('checkOutDate').value);
            let soNgay = Math.ceil((checkOut - checkIn) / (1000 * 60 * 60 * 24));
            if (isNaN(soNgay) || soNgay <= 0) soNgay = 1; // Default to 1 night if invalid
            
            document.getElementById('soNgay').textContent = soNgay;

            let tienPhong = 0;
            const roomId = document.getElementById('roomId').value;
            
            // Lấy giá động từ server
            if (!isNaN(checkIn.getTime()) && !isNaN(checkOut.getTime()) && checkOut > checkIn) {
                try {
                    const res = await fetch('/datphong/calculate-price', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            roomId: roomId,
                            checkInDate: document.getElementById('checkInDate').value,
                            checkOutDate: document.getElementById('checkOutDate').value
                        })
                    });
                    const data = await res.json();
                    if (data.success) {
                        tienPhong = data.totalRoomCost;
                    } else {
                        // Fallback to base price calculation
                        const roomPrice = parseFloat(modal.dataset.roomPrice) || ROOM_PRICE_PER_NIGHT;
                        tienPhong = soNgay * roomPrice;
                    }
                } catch (e) {
                    const roomPrice = parseFloat(modal.dataset.roomPrice) || ROOM_PRICE_PER_NIGHT;
                    tienPhong = soNgay * roomPrice;
                }
            } else {
                const roomPrice = parseFloat(modal.dataset.roomPrice) || ROOM_PRICE_PER_NIGHT;
                tienPhong = soNgay * roomPrice;
            }

            document.getElementById('tienPhong').textContent = tienPhong.toLocaleString('vi-VN') + ' VNĐ';

            let tienDichVu = 0;
            inputServices.forEach(input => {
                const sl = parseInt(input.value) || 0;
                const price = parseInt(input.getAttribute('data-price')) || 0;
                tienDichVu += sl * price;
            });
            document.getElementById('tienDichVu').textContent = tienDichVu.toLocaleString('vi-VN') + ' VNĐ';

            // Phụ thu logic
            const numNguoiLon = parseInt(document.getElementById('modalNguoiLon').value, 10) || 1;
            const numTreEm = parseInt(document.getElementById('modalTreEm').value, 10) || 0;
            
            let tienPhuThu = 0;
            // Phụ thu người lớn (vượt quá tiêu chuẩn)
            const numExtraAdults = Math.max(0, numNguoiLon - ROOM_TYPE_MAX_ADULTS);
            const adultSurcharge = numExtraAdults * 200000 * soNgay; // 200k/người lớn/đêm
            tienPhuThu += adultSurcharge;
            
            const adultWarningEl = document.getElementById('adultWarning');
            if (numExtraAdults > 0) {
                adultWarningEl.textContent = `*Phụ thu thêm ${numExtraAdults} người: ${(adultSurcharge).toLocaleString('vi-VN')} VNĐ`;
                adultWarningEl.classList.remove('d-none');
            } else {
                adultWarningEl.classList.add('d-none');
            }
            
            // Phụ thu trẻ em (Trẻ em thứ 2 trở đi)
            let childSurcharge = 0;
            if (numTreEm > 1) {
                childSurcharge = (numTreEm - 1) * 100000 * soNgay; // 100k/trẻ/đêm
                tienPhuThu += childSurcharge;
            }

            const childWarningEl = document.getElementById('childWarning');
            if (numTreEm > 1) {
                childWarningEl.textContent = `*Phụ thu thêm ${numTreEm - 1} trẻ: ${(childSurcharge).toLocaleString('vi-VN')} VNĐ`;
                childWarningEl.classList.remove('d-none');
            } else {
                childWarningEl.classList.add('d-none');
            }

            document.getElementById('tienPhuThu').textContent = tienPhuThu.toLocaleString('vi-VN') + ' VNĐ';
            
            const tong = tienPhong + tienDichVu + tienPhuThu;
            document.getElementById('tongTien').textContent = tong.toLocaleString('vi-VN') + ' VNĐ';
            const tienCoc = Math.round(tong / 2); // 50% cọc
            document.getElementById('tienCoc').textContent = tienCoc.toLocaleString('vi-VN') + ' VNĐ';
        }

        // Tự động tính ngay khi vừa mở modal
        // Lắng nghe MutationObserver để tính khi class 'open' được thêm vào
        const observer = new MutationObserver((mutations) => {
            mutations.forEach((mutation) => {
                if (mutation.attributeName === 'class' && modal.classList.contains('open')) {
                    calculateTotal();
                    const phone = document.getElementById('phone').value;
                    const ckContent = `DP ${phone || '[Số điện thoại]'}`;
                    document.getElementById('noiDungCK').textContent = ckContent;
                    document.getElementById('noiDungCK2').textContent = ckContent;
                }
            });
        });
        observer.observe(modal, { attributes: true });

        // Nút "XÁC NHẬN ĐẶT PHÒNG"
        btnDat.addEventListener('click', () => {
            const checkInDate = new Date(document.getElementById('checkInDate').value);
            const checkOutDate = new Date(document.getElementById('checkOutDate').value);
            
            if (isNaN(checkInDate.getTime()) || isNaN(checkOutDate.getTime())) {
                alert('Vui lòng chọn ngày nhận và ngày trả phòng!');
                return;
            }
            if (checkOutDate <= checkInDate) {
                alert('Ngày trả phòng phải sau ngày nhận phòng!');
                return;
            }
            
            const fullName = document.getElementById('fullName').value.trim();
            const phone = document.getElementById('phone').value.trim();
            if (!fullName || !phone) {
                alert('Vui lòng nhập đầy đủ Họ tên và Số điện thoại!');
                return;
            }
            
            const services = [];
            inputServices.forEach(input => {
                const quantity = parseInt(input.value, 10) || 0;
                if (quantity > 0) {
                    // Extract ID from 'service_ID'
                    const serviceId = input.id.replace('service_', '');
                    services.push({
                        id: serviceId,
                        quantity: quantity,
                        price: parseInt(input.dataset.price)
                    });
                }
            });

            const data = {
                roomId: document.getElementById('roomId').value,
                checkInDate: document.getElementById('checkInDate').value,
                checkOutDate: document.getElementById('checkOutDate').value,
                fullName: fullName,
                phone: phone,
                email: document.getElementById('email').value,
                nguoiLon: parseInt(document.getElementById('modalNguoiLon').value, 10),
                treEm: parseInt(document.getElementById('modalTreEm').value, 10),
                services: services,
                source: 'website'
            };

            // Show loading state
            btnDat.disabled = true;
            btnDat.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> ĐANG XỬ LÝ...';

            fetch('/datphong', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => {
                 if (!res.ok) {
                    return res.json().then(errData => { throw new Error(errData.message || 'Lỗi không xác định'); });
                }
                return res.json();
            })
            .then(res => {
                if (res.message === 'success') {
                    if (window.activePayTab === 'qr') {
                        // Gọi API tạo URL VNPay
                        fetch('/payment/create_payment_url', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ 
                                bookingId: res.data._id,
                                amount: res.data.depositAmount
                            })
                        })
                        .then(payRes => payRes.json())
                        .then(payData => {
                            if (payData.code === '00') {
                                window.location.href = payData.data;
                            } else {
                                alert('Không thể kết nối với cổng thanh toán VNPay. Vui lòng thử lại sau.');
                                window.location.reload();
                            }
                        })
                        .catch(err => {
                            console.error('Lỗi VNPay:', err);
                            alert('Lỗi tạo thanh toán VNPay.');
                            window.location.reload();
                        });
                    } else {
                        alert('Đặt phòng thành công! Vui lòng chuyển khoản theo thông tin đã cung cấp.');
                        window.location.reload();
                    }
                } else {
                    alert('Đặt phòng thất bại: ' + res.message);
                    btnDat.disabled = false;
                    btnDat.textContent = 'XÁC NHẬN ĐẶT PHÒNG';
                }
            })
            .catch(err => {
                console.error('Lỗi khi gửi booking:', err);
                alert('Đặt phòng thất bại: ' + err.message);
                btnDat.disabled = false;
                btnDat.textContent = 'XÁC NHẬN ĐẶT PHÒNG';
            });
        });
    });
</script>

<script>
    window.activePayTab = 'qr';
    function switchPayTab(tab) {
        window.activePayTab = tab;
        const panelQR = document.getElementById('panelQR');
        const panelCard = document.getElementById('panelCard');
        const tabQR = document.getElementById('tabQR');
        const tabCard = document.getElementById('tabCard');
        if (tab === 'qr') {
            panelQR.style.display = 'block';
            panelCard.style.display = 'none';
            tabQR.style.color = '#00796B';
            tabQR.style.borderBottom = '3px solid #00796B';
            tabCard.style.color = '#6b7280';
            tabCard.style.borderBottom = '3px solid transparent';
        } else {
            panelQR.style.display = 'none';
            panelCard.style.display = 'block';
            tabQR.style.color = '#6b7280';
            tabQR.style.borderBottom = '3px solid transparent';
            tabCard.style.color = '#00796B';
            tabCard.style.borderBottom = '3px solid #00796B';
        }
    }
</script>





