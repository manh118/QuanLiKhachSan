<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
    .room-detail-container {
        font-family: 'Montserrat', sans-serif;
        background-color: #f9fafb;
        color: #1f2937;
        padding-top: 2rem;
        padding-bottom: 4rem;
        font-size: 1.4rem; /* Tăng base font size */
    }
    .text-hotel-teal { color: #00796B !important; }
    .bg-hotel-teal { background-color: #00796B !important; color: white !important; }
    .border-hotel-teal { border-color: #00796B !important; }
    .hover-bg-hotel-teal:hover { background-color: #004D40 !important; color: white !important; }
    
    .rd-gallery {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
        height: auto;
        margin-bottom: 3.5rem; /* Tăng lề dưới */
    }
    @media (min-width: 768px) {
        .rd-gallery {
            grid-template-columns: repeat(4, 1fr);
            grid-template-rows: repeat(2, 1fr);
            height: 550px; /* Tăng chiều cao ảnh */
        }
        .rd-main-img {
            grid-column: span 3;
            grid-row: span 2;
        }
    }
    .rd-img-wrapper {
        border-radius: 0.5rem; /* Bo góc ít hơn */
        overflow: hidden;
        position: relative;
    }
    .rd-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }
    .rd-img-wrapper:hover img {
        transform: scale(1.03);
    }

    .rd-content-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem; /* Tăng khoảng cách 2 cột */
    }
    @media (min-width: 992px) {
        .rd-content-layout {
            grid-template-columns: 2fr 1fr;
        }
    }

    .rd-badge {
        background-color: #f3f4f6; /* Màu xám nhạt hơn */
        padding: 0.5rem 1.2rem;
        border-radius: 9999px;
        display: inline-flex;
        align-items: center;
        font-size: 1.2rem; /* Chữ to hơn */
        margin-right: 1rem;
        margin-bottom: 1rem;
        color: #4b5563;
    }

    .rd-section-title {
        font-size: 1.8rem; /* Tiêu đề to hơn */
        font-weight: 700;
        color: #00796B;
        margin-bottom: 2rem;
        border-left: 5px solid #00796B; /* Viền dày hơn */
        padding-left: 1rem;
    }

    .rd-amenities-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
    }
    @media (min-width: 576px) {
        .rd-amenities-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @media (min-width: 768px) {
        .rd-amenities-grid { grid-template-columns: repeat(5, 1fr); }
    }
    .rd-amenity-card {
        border: 1px solid #e5e7eb;
        border-radius: 0.25rem; /* Bo góc ít hơn */
        padding: 1.5rem 1rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        background-color: white;
        transition: box-shadow 0.3s, border-color 0.3s;
    }
    .rd-amenity-card:hover {
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        border-color: #00796B;
    }
    .rd-amenity-icon {
        font-size: 2.2rem; /* Icon to hơn */
        margin-bottom: 1rem;
        color: #00796B;
    }

    .rd-sidebar-card {
        background: white;
        border-radius: 0.5rem; /* Bo góc ít */
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        border: 1px solid #e5e7eb;
        top: 6rem;
    }
    
    .rd-related-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }
    @media (min-width: 768px) {
        .rd-related-grid { grid-template-columns: repeat(3, 1fr); }
    }
    
    .rd-related-card {
        background: white;
        border-radius: 0.5rem;
        border: 1px solid #e5e7eb;
        overflow: hidden;
        transition: box-shadow 0.3s;
    }
    .rd-related-card:hover {
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }

    /* Bootstrap Overrides for new styles */
    .hover-text-hotel-teal:hover {
        color: #00796B !important;
    }
    
    /* Chỉnh cỡ chữ text chung */
    .rd-text-body {
        font-size: 1.4rem;
        color: #6b7280;
        line-height: 1.8;
    }
    .rd-title-main {
        font-size: 2.8rem;
        color: #1f2937;
        font-weight: 700;
        margin-bottom: 1.5rem;
    }
</style>

<div class="room-detail-container mt-5">
    <div class="container" style="max-width: 1400px;"> <!-- Mở rộng container giống UI xịn -->
        <!-- Gallery -->
        <section class="rd-gallery">
            <div class="rd-img-wrapper rd-main-img group">
                <img src="{{Room.img}}" alt="Hình ảnh chính phòng {{Room.roomNumber}}">
            </div>
            <!-- Thêm ảnh tạm cho đủ lưới -->
            <div class="rd-img-wrapper d-none d-md-block">
                <img src="/img/room-thumb-1.jpg" onerror="this.src='{{Room.img}}'" alt="Thumb 1">
            </div>
            <div class="rd-img-wrapper d-none d-md-block">
                <img src="/img/room-thumb-2.jpg" onerror="this.src='{{Room.img}}'" alt="Thumb 2">
            </div>
        </section>

        <div class="rd-content-layout">
            <!-- Main Content -->
            <div class="rd-main-content">
                <div class="border-bottom pb-4 mb-5">
                    <h1 class="rd-title-main">Phòng: {{Room.roomNumber}} - {{Room.roomType.name}}</h1>
                    <div class="d-flex flex-wrap">
                        <span class="rd-badge"><i class="fa-solid fa-bed mr-2" style="color:#9ca3af;"></i> {{Room.bedType.name}}</span>
                        <span class="rd-badge"><i class="bx bx-area mr-2" style="color:#9ca3af;"></i> Diện tích: {{{m2 Room.area}}}</span>
                        <span class="rd-badge"><i class="fa-solid fa-users mr-2" style="color:#9ca3af;"></i> Tối đa: {{Room.roomType.maxAdults}} người</span>
                    </div>
                </div>

                <article class="mb-5">
                    <h2 class="rd-section-title">Mô tả chi tiết</h2>
                    <p class="text-justify rd-text-body">
                        {{Room.roomType.description}}
                    </p>
                </article>

                <section class="mb-5">
                    <h2 class="rd-section-title">Tiện nghi phòng</h2>
                    <div class="rd-amenities-grid">
                        {{#each Room.roomType.utilities}}
                        <div class="rd-amenity-card">
                            <i class="{{this.icon}} rd-amenity-icon"></i>
                            <span class="font-weight-bold text-uppercase" style="font-size: 1.1rem; color: #374151;">{{this.name}}</span>
                        </div>
                        {{/each}}
                    </div>
                </section>

                <section class="mb-5">
                    <h2 class="rd-section-title">Chính sách & Quy định</h2>
                    <div class="p-4 p-md-5 rounded" style="background-color: #f8f9fa;">
                        <div class="row">
                            <div class="col-md-6 mb-4 mb-md-0">
                                <h5 class="font-weight-bold mb-3" style="font-size: 1.6rem; color: #1f2937;"><i class="fa-regular fa-clock mr-2"></i> Thời gian Nhận/Trả phòng</h5>
                                <ul class="rd-text-body pl-4" style="list-style-type: none; padding-left: 0;">
                                    <li class="mb-2"><span style="color:#9ca3af; margin-right: 8px;">•</span>Nhận phòng: từ 14:00</li>
                                    <li><span style="color:#9ca3af; margin-right: 8px;">•</span>Trả phòng: trước 12:00</li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <h5 class="font-weight-bold mb-3" style="font-size: 1.6rem; color: #1f2937;"><i class="fa-solid fa-clipboard-list mr-2"></i> Quy định chung</h5>
                                <ul class="rd-text-body pl-4" style="list-style-type: none; padding-left: 0;">
                                    <li class="mb-2"><span style="color:#9ca3af; margin-right: 8px;">•</span>Không hút thuốc trong phòng</li>
                                    <li class="mb-2"><span style="color:#9ca3af; margin-right: 8px;">•</span>Không mang theo thú cưng</li>
                                    <li><span style="color:#9ca3af; margin-right: 8px;">•</span>Giữ yên tĩnh sau 22:00</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <!-- Sidebar -->
            <aside>
                <div class="rd-sidebar-card mb-5" style="z-index: 10;">
                    <div class="bg-hotel-teal p-5 text-center" style="border-radius: 0.5rem 0.5rem 0 0;">
                        <p class="text-uppercase mb-2" style="font-size: 1.2rem; letter-spacing: 1px; color: rgba(255,255,255,0.9);">Giá chỉ từ</p>
                        <h3 class="font-weight-bold mb-1" style="font-size: 3.2rem;">{{money Room.roomType.price}} VNĐ</h3>
                        <p class="mb-0" style="font-size: 1.1rem; color: rgba(255,255,255,0.9);">/ ĐÊM</p>
                    </div>
                    <div class="p-5">
                        <button type="button" class="btn btn-block bg-hotel-teal text-white py-3 rounded js-show-room-calendar-modal hover-bg-hotel-teal" data-room-id="{{Room._id}}" data-room-number="{{Room.roomNumber}}" data-room-price="{{Room.roomType.price}}" style="font-size: 1.5rem; font-weight: bold; transition: all 0.3s; border: none; letter-spacing: 0.5px;">
                            XEM LỊCH ĐẶT PHÒNG
                        </button>
                        <p class="text-center mt-3 mb-0" style="font-size: 1.1rem; color: #9ca3af;">Cam kết giá tốt nhất khi đặt trực tiếp</p>
                    </div>
                </div>

                <div class="bg-white p-5 rounded border">
                    <h4 class="font-weight-bold border-bottom pb-3 mb-4" style="font-size: 1.8rem; color: #1f2937;">Hạng phòng khác</h4>
                    {{#each RoomTypes}}
                        {{#unless (eq this._id ../currentRoomTypeId)}}
                        <a href="/hangphong/{{this._id}}/rooms" class="d-flex align-items-center mb-4 text-decoration-none text-dark group hover-text-hotel-teal">
                            <div class="rounded overflow-hidden mr-4 position-relative" style="width: 90px; height: 90px; flex-shrink: 0;">
                                <img src="{{this.img}}" alt="{{this.name}}" style="width:100%; height:100%; object-fit:cover; transition: transform 0.3s;" class="group-hover-img">
                            </div>
                            <div>
                                <h6 class="font-weight-bold mb-2" style="font-size: 1.4rem; transition: color 0.2s;">{{this.name}}</h6>
                                <p class="text-hotel-teal font-weight-bold mb-0" style="font-size: 1.2rem;">{{money this.price}} VNĐ</p>
                            </div>
                        </a>
                        {{/unless}}
                    {{/each}}
                </div>
            </aside>
        </div>

        <!-- Related Rooms -->
        <section class="mt-5 pt-5">
            <div class="d-flex justify-content-between align-items-end mb-5 border-bottom pb-3">
                <h2 class="rd-section-title mb-0 border-0 pl-0 mt-5">Phòng liên quan</h2>
            </div>
            
            <div class="rd-related-grid">
                {{#each RelatedRooms}}
                <div class="rd-related-card position-relative">
                    <div style="height: 250px; position: relative; overflow: hidden;">
                        <img src="{{this.img}}" alt="Phòng {{this.roomNumber}}" style="width:100%; height:100%; object-fit:cover; transition: transform 0.5s;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                        
                        {{#if (eqString this.status 'Đã đặt')}}
                            <span class="badge badge-warning position-absolute" style="top: 15px; left: 15px; font-size: 1.1rem; padding: 6px 12px; z-index: 2;">Đã đặt</span>
                        {{else}}
                            <span class="badge position-absolute bg-hotel-teal text-white" style="top: 15px; left: 15px; font-size: 1.1rem; padding: 6px 12px; z-index: 2;">✓ Trống</span>
                        {{/if}}
                        
                        <div class="position-absolute w-100 text-center p-3 font-weight-bold text-white shadow" style="bottom: 0; background: linear-gradient(to top, rgba(0,0,0,0.8), transparent); font-size: 1.4rem;">
                            {{money this.price}} VNĐ/ĐÊM
                        </div>
                    </div>
                    <div class="p-4" style="background: white;">
                        <h4 class="font-weight-bold mb-2" style="font-size: 1.6rem; color: #1f2937;">{{this.roomType.name}}</h4>
                        <p class="rd-text-body mb-3"><i class="fa-solid fa-door-open mr-2" style="color: #9ca3af;"></i> Phòng: {{this.roomNumber}}</p>
                        
                        <div class="d-flex justify-content-between rd-text-body mb-4" style="border-top: 1px solid #f3f4f6; padding-top: 15px;">
                            <span><i class="fa-solid fa-bed mr-2" style="color: #9ca3af;"></i> {{this.bedType.name}}</span>
                            <span><i class="bx bx-area mr-2" style="color: #9ca3af;"></i> {{{m2 this.area}}}</span>
                        </div>
                        <a href="/hangphong/room/{{this.roomNumber}}" class="btn btn-block font-weight-bold bg-light py-2" style="color: #00796B; font-size: 1.4rem; border: 1px solid rgba(0, 121, 107, 0.2); transition: all 0.3s;" onmouseover="this.style.backgroundColor='#00796B'; this.style.color='white'" onmouseout="this.style.backgroundColor='#f8f9fa'; this.style.color='#00796B'">Chi tiết phòng</a>
                    </div>
                </div>
                {{/each}}
            </div>
        </section>
    </div>
</div>
</div>

<div class="modal fade" id="roomCalendarModal" tabindex="-1" role="dialog" aria-labelledby="roomCalendarModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="roomCalendarModalLabel">Lịch Trống - Phòng {{Room.roomNumber}}</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        {{!-- Nút chuyển tháng --}}
        <div class="d-flex justify-content-between mb-3 calendar-nav">
            <button class="btn btn-sm btn-outline-secondary js-prev-month">&lt; Tháng Trước</button>
            <h5 class="calendar-month-year"></h5>
            <button class="btn btn-sm btn-outline-secondary js-next-month">Tháng Sau &gt;</button>
        </div>
         {{!-- Div để JavaScript vẽ lịch vào --}}
        <div id="room-calendar-container" class="table-responsive">
            {{!-- Lịch sẽ được tạo ở đây bằng JS --}}
        </div>
         {{!-- Chú thích --}}
         <div class="mt-3 d-flex justify-content-end">
             <span class="mr-3"><span class="legend-color legend-available"></span> Còn trống</span>
             <span class="mr-3"><span class="legend-color legend-past"></span> Quá khứ</span>
             <span class="mr-3"><span class="legend-color legend-booked"></span> Đã đặt</span>
         </div>
      </div>
    </div>
  </div>
</div>

<div class="modal__booking js-modal__booking">
    <div class="modal__booking__container modern-booking-modal" style="width: 1000px; max-height: 90vh; border-radius: 12px; overflow: hidden; display: flex; flex-direction: column; background: #fff;">
        
        <!-- Header -->
        <div class="bg-hotel-teal text-white p-4 d-flex justify-content-between align-items-center">
            <h3 class="mb-0 font-weight-bold" style="font-size: 2.2rem; color: #fff;"><i class="fa-solid fa-calendar-check mr-2"></i> ĐẶT PHÒNG <span id="modalRoomName">- Phòng {{Room.roomNumber}}</span></h3>
            <div class="modal__booking__close" style="position: static; font-size: 2.5rem; color: white; cursor: pointer;">
                <i class="fa-solid fa-xmark" style="color: white;"></i>
            </div>
        </div>
        
        <input type="hidden" id="roomId" value="{{Room._id}}">

        <!-- Body -->
        <div class="row m-0 flex-grow-1" style="overflow-y: auto; background-color: #f3f4f6;">
            <!-- Cột trái: Form -->
            <div class="col-md-7 p-4 bg-white">
                <h4 class="font-weight-bold mb-4" style="color: #1f2937; font-size: 1.8rem; border-left: 4px solid #00796B; padding-left: 10px;">Thông tin Đặt phòng</h4>
                
                <div class="row">
                    <div class="col-6 mb-3">
                        <label class="font-weight-bold" style="color: #4b5563; font-size: 1.4rem;">Nhận phòng</label>
                        <input type="Date" id="checkInDate" class="form-control form-control-lg bg-light" style="font-size: 1.4rem;">
                    </div>
                    <div class="col-6 mb-3">
                        <label class="font-weight-bold" style="color: #4b5563; font-size: 1.4rem;">Trả phòng</label>
                        <input type="Date" id="checkOutDate" class="form-control form-control-lg bg-light" style="font-size: 1.4rem;">
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-6">
                        <label class="font-weight-bold" style="color: #4b5563; font-size: 1.4rem;">Người lớn</label>
                        <div class="d-flex align-items-center justify-content-between p-2 border rounded bg-light">
                            <button type="button" class="btn btn-sm btn-outline-secondary js-qty-btn" data-target="modalNguoiLon" data-action="minus"><i class="fa-solid fa-minus"></i></button>
                            <span class="font-weight-bold" style="font-size: 1.6rem; width: 30px; text-align: center;" id="modalNguoiLonDisplay">1</span>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-qty-btn" data-target="modalNguoiLon" data-action="plus"><i class="fa-solid fa-plus"></i></button>
                            <input type="hidden" id="modalNguoiLon" value="1">
                        </div>
                        <small id="adultWarning" class="text-danger d-none mt-1" style="font-size: 1.2rem;"></small>
                    </div>
                    <div class="col-6">
                        <label class="font-weight-bold" style="color: #4b5563; font-size: 1.4rem;">Trẻ em</label>
                        <div class="d-flex align-items-center justify-content-between p-2 border rounded bg-light">
                            <button type="button" class="btn btn-sm btn-outline-secondary js-qty-btn" data-target="modalTreEm" data-action="minus"><i class="fa-solid fa-minus"></i></button>
                            <span class="font-weight-bold" style="font-size: 1.6rem; width: 30px; text-align: center;" id="modalTreEmDisplay">0</span>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-qty-btn" data-target="modalTreEm" data-action="plus"><i class="fa-solid fa-plus"></i></button>
                            <input type="hidden" id="modalTreEm" value="0">
                        </div>
                        <small id="childWarning" class="text-danger d-none mt-1" style="font-size: 1.2rem;"></small>
                    </div>
                </div>

                <h4 class="font-weight-bold mb-4 mt-5" style="color: #1f2937; font-size: 1.8rem; border-left: 4px solid #00796B; padding-left: 10px;">Thông tin Khách hàng</h4>
                <div class="mb-3">
                    <label class="font-weight-bold" style="color: #4b5563; font-size: 1.4rem;">Họ và tên</label>
                    <input type="Text" id="fullName" class="form-control form-control-lg" style="font-size: 1.4rem;" value="{{user.fullName}}">
                </div>
                <div class="row mb-4">
                    <div class="col-6">
                        <label class="font-weight-bold" style="color: #4b5563; font-size: 1.4rem;">Số điện thoại</label>
                        <input type="Text" id="phone" class="form-control form-control-lg" style="font-size: 1.4rem;" value="{{user.phone}}">
                    </div>
                    <div class="col-6">
                        <label class="font-weight-bold" style="color: #4b5563; font-size: 1.4rem;">Email</label>
                        <input type="Text" id="email" class="form-control form-control-lg" style="font-size: 1.4rem;" value="{{user.email}}">
                    </div>
                </div>
                
                <h4 class="font-weight-bold mb-3 mt-5" style="color: #1f2937; font-size: 1.8rem; border-left: 4px solid #00796B; padding-left: 10px;">Dịch vụ thêm (Tùy chọn)</h4>
                <div class="service-list">
                    {{#each Services}}
                    <div class="d-flex justify-content-between align-items-center p-3 mb-2 border rounded bg-light" style="transition: box-shadow 0.2s;">
                        <div>
                            <h6 class="mb-0 font-weight-bold" style="color: #00796B; font-size: 1.4rem;">{{this.name}}</h6>
                            <small class="text-muted" style="font-size: 1.2rem;">{{money this.price}} VNĐ / {{this.unit}}</small>
                        </div>
                        <div class="d-flex align-items-center">
                            <button type="button" class="btn btn-sm btn-outline-secondary js-service-btn" data-target="service_{{this._id}}" data-action="minus"><i class="fa-solid fa-minus"></i></button>
                            <span class="font-weight-bold mx-3" style="font-size: 1.4rem; width: 20px; text-align: center;" id="display_service_{{this._id}}">0</span>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-service-btn" data-target="service_{{this._id}}" data-action="plus"><i class="fa-solid fa-plus"></i></button>
                            <input type="hidden" class="modal__booking__service__input" id="service_{{this._id}}" name="{{this._id}}" data-price="{{this.price}}" value="0">
                        </div>
                    </div>
                    {{/each}}
                </div>
            </div>

            <!-- Cột phải: Summary -->
            <div class="col-md-5 p-4 border-left" style="background-color: #f8f9fa;">
                <h4 class="font-weight-bold mb-4" style="color: #1f2937; font-size: 1.8rem;">Tóm tắt Đơn hàng</h4>
                
                <div class="bg-white p-4 rounded border mb-4 shadow-sm" style="font-size: 1.4rem;">
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Số đêm:</span>
                        <span class="font-weight-bold" id="soNgay">0</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Tiền phòng:</span>
                        <span class="font-weight-bold" id="tienPhong">0 VNĐ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Tiền dịch vụ:</span>
                        <span class="font-weight-bold" id="tienDichVu">0 VNĐ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4 border-bottom pb-4">
                        <span class="text-muted">Phụ thu khách thêm:</span>
                        <span class="font-weight-bold text-danger" id="tienPhuThu">0 VNĐ</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="font-weight-bold" style="font-size: 1.6rem; color: #1f2937;">TỔNG TIỀN:</span>
                        <span class="font-weight-bold text-danger" style="font-size: 2.2rem;" id="tongTien">0 VNĐ</span>
                    </div>
                </div>

                <div class="rounded mb-4" style="border: 1.5px solid #e0f2f1; background: #f0fdfb; padding: 0; overflow: hidden;">
                    <!-- Header -->
                    <div style="background: linear-gradient(135deg, #00796B, #009688); padding: 1.2rem 1.5rem; text-align: center;">
                        <h5 class="font-weight-bold mb-0 text-white" style="font-size: 1.5rem; letter-spacing: 0.5px;">
                            <i class="fa-solid fa-shield-halved mr-2"></i> Thanh Toán Đặt Cọc (50%)
                        </h5>
                    </div>

                    <!-- Amount Display -->
                    <div style="text-align: center; padding: 1.2rem 1.5rem 0.5rem; border-bottom: 1px solid #e0f2f1;">
                        <p class="mb-1 text-muted" style="font-size: 1.1rem;">Số tiền cần thanh toán:</p>
                        <span style="font-size: 2.8rem; font-weight: 800; color: #00796B; letter-spacing: -0.5px;" id="tienCoc">0 VNĐ</span>
                    </div>

                    <!-- Thanh toán qua VNPay info -->
                    <div style="padding: 1.2rem 1.5rem; text-align: center;">
                        <p class="text-muted mb-3" style="font-size: 1.2rem;">Hệ thống sẽ chuyển hướng bạn tới <strong>Cổng thanh toán VNPay</strong> sau khi ấn Xác nhận.</p>
                        <img src="/img/Logo/VNPAY.jpg" alt="VNPay Logo" style="height: auto; width: 140px; display: block; margin: 0 auto;">
                    </div>
                </div>


                <button type="button" class="btn btn-block bg-hotel-teal text-white py-3 rounded font-weight-bold modal__booking__btn hover-bg-hotel-teal" style="font-size: 1.8rem; width: 100%; border: none;">XÁC NHẬN ĐẶT PHÒNG</button>
            </div>
        </div>
    </div>
