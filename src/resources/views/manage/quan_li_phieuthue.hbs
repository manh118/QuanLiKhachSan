                <button type="button" class="btn modal__booking__btn js-submit-checkin" style="background-color: rgb(34, 136, 253); border: none; font-size: 1.6rem; font-weight: bold; width: auto; min-width: 200px; white-space: nowrap; padding: 10px 20px;">Xác Nhận Check-in</button>
            </div>
