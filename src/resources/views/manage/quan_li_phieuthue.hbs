  <div class="row manage_body">
    <div class="col-12 ">
      <div class="form_quanliphong">
         <div class="d-flex justify-content-between align-items-start mb-4"> {{!-- Flexbox: space-between --}}
                {{!-- Tiêu đề bên trái --}}
                <h2 style="margin-bottom: 0;">Danh sách phiếu thuê</h2>

                <form class="form__sreach ql_phieuthue d-flex align-items-center" style="gap: 10px; flex-wrap: wrap;" method="GET" action="/manage/quan_li_phieuthue">
                    <div class="input-group" style="width: auto;">
                         <input class="form-control px-3 py-4" style="font-size: 1.3rem;" name="q" type="search" placeholder="Nhập tên khách hàng" value="{{searchQuery}}">
                    </div>
                    <div class="input-group" style="width: auto;">
                         <input class="form-control px-3 py-4" style="font-size: 1.3rem;" name="q1" type="search" placeholder="Nhập số điện thoại" value="{{searchPhone}}">
                    </div>
                    <div class="input-group" style="width: auto;">
                         <input class="form-control px-3 py-4" style="font-size: 1.3rem;" name="q2" type="search" placeholder="Nhập mã phiếu" value="{{searchCode}}">
                    </div>
                    <div class="input-group" style="width: auto;">
                         <input class="form-control px-3 py-4" style="font-size: 1.3rem;" name="q3" type="search" placeholder="Nhập số phòng" value="{{searchRoom}}">
                    </div>
                    <button class="btn btn-primary px-4 py-2" style="font-size: 1.4rem; height: 100%;">Lọc</button>
                </form>
            </div>
            <div style="overflow-x: auto; white-space: nowrap;"> 
                <table class="table mt-4" style="min-width: 1400px;">
                    <thead>
                        <tr> 
                            <th scope="col">STT</th>
                            <th scope="col">Mã phiếu</th>
                            <th scope="col">Phòng</th>
                            <th scope="col">Khách hàng</th>
                            <th scope="col">Số điện thoại</th>
                            <th scope="col">Ngày đặt</th> 
                            <th scope="col">Ngày trả</th>   
                            <th scope="col">Tổng tiền</th>
                            <th scope="col">Trạng thái</th>                          
                            <th scope="col" class="text-center">Thao tác</th>
                            <th scope="col" class="text-center">Tùy chọn</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each Bookings}}
                        <tr {{#if this.isOverdue}}style="background-color: #ffe6e6;"{{/if}}>                       
                            <th scope="row" class="align-middle">{{sum @index 1}}</th>
                            <td class="align-middle" style="font-weight: bold; color: #007bff;">{{this.shortCode}}</td>
                            <td class="align-middle">{{this.roomNumber}}</td>
                            <td class="align-middle">{{this.customer.fullName}}</td>
                            <td class="align-middle">{{this.customer.phone}}</td>
                            <td class="align-middle">{{Date this.checkInDate}}</td>  
                            <td class="align-middle">{{Date this.checkOutDate}}</td>
                            <td class="align-middle">{{money this.totalAmount}} VNĐ</td>
                            <td class="align-middle">
                                {{!-- Hiển thị trạng thái với màu sắc --}}
                                {{#if (eqString this.bookingStatus 'Pending Deposit')}}
                                    <span class="badge badge-warning">{{this.bookingStatus}}</span>
                                {{else if (eqString this.bookingStatus 'Confirmed')}}
                                    <span class="badge badge-success">{{this.bookingStatus}}</span>
                                {{else if (eqString this.bookingStatus 'Checked In')}}
                                    <span class="badge badge-info">{{this.bookingStatus}}</span>
                                    {{#if this.isOverdue}}
                                        <span class="badge badge-danger blink-warning" style="margin-left: 5px;">⚠️ Quá hạn</span>
                                    {{/if}}
                                {{else if (eqString this.bookingStatus 'Checked Out')}}
                                    <span class="badge badge-secondary">{{this.bookingStatus}}</span>
                                {{else}}
                                    <span class="badge badge-danger">{{this.bookingStatus}}</span>
                                {{/if}}
                            </td>
                            <td class="align-middle">
                                <div class="d-flex align-items-center justify-content-center" style="gap: 8px;">
                                    {{!-- Main action button --}}
                                    {{#if (eqString this.bookingStatus 'Pending Deposit')}}
                                        <span class="text-muted" style="font-size: 1.2rem; font-style: italic;">Chờ thanh toán</span>
                                    {{else if (eqString this.bookingStatus 'Confirmed')}}
                                        <button type="button" class="btn btn-outline-info btn-sm js-CheckInModalBtn" 
                                                data-id="{{this._id}}"
                                                data-room="{{this.roomNumber}}"
                                                data-fullname="{{this.customer.fullName}}"
                                                data-phone="{{this.customer.phone}}">Check-in</button>
                                    {{else if (eqString this.bookingStatus 'Checked In')}}
                                        <button class="btn btn-outline-primary btn-sm js-TraPhong"
                                            data-id="{{this._id}}"
                                            data-room="{{this.roomNumber}}"
                                            data-fullname="{{this.customer.fullName}}"
                                            data-phone="{{this.customer.phone}}"
                                            data-checkin="{{isoDate this.checkInDate }}"
                                            data-checkout="{{isoDate this.checkOutDate }}"
                                            data-total="{{money this.totalAmount}}" 
                                            data-deposit="{{money this.depositAmount}}" 
                                            data-remaining="{{money this.remainingAmount}}">Thanh toán</button>
                                    {{/if}}

                                    {{!-- Cancel button --}}
                                    {{#if (or (eqString this.bookingStatus 'Pending Deposit') (eqString this.bookingStatus 'Confirmed'))}}
                                        <form method="POST" action="/manage/quan_li_phieuthue/crud/{{this._id}}/cancel?_method=PUT" style="margin: 0;" class="form-cancel-booking"> 
                                            <button type="submit" class="btn btn-outline-danger btn-sm">Hủy</button>
                                        </form>
                                    {{/if}}
                                </div>
                            </td>
                            <td class="align-middle">
                                <div class="d-flex align-items-center justify-content-center" style="gap: 8px;">
                                    {{!-- Chi tiết button --}}
                                    <button class="btn btn-outline-secondary btn-sm" type="button" data-toggle="collapse" data-target="#collapse-{{@index}}" aria-expanded="false" aria-controls="collapse-{{@index}}">
                                        Chi tiết
                                    </button>

                                    {{!-- Cập nhật button (Ẩn nếu đã checkout hoặc hủy) --}}
                                    {{#unless (or (eqString this.bookingStatus 'Checked Out') (eqString this.bookingStatus 'Cancelled'))}}
                                        <a href="/manage/quan_li_phieuthue/crud/{{this._id}}/show_update" class="btn btn-outline-dark btn-sm">Cập nhật</a>
                                    {{/unless}}
                                </div>
                            </td>
                        </tr>  
  
                        <tr class="collapse" id="collapse-{{@index}}">  
                            <td colspan="100%">
                                <div class="p-3 text-left" style="background-color: #f8f9fa; border: 1px solid #dee2e6; border-radius: 0.25rem;">
                                <p><strong>Người lớn:</strong> {{this.nguoiLon}}</p>
                                <p><strong>Trẻ em:</strong> {{this.treEm}}</p>
                                 <p><strong>Dịch vụ đã sử dụng:</strong></p>
                                 <ul>
                                        {{#each this.services}}
                                        <li>{{this.service.name}} (SL: {{this.quantity}} × {{money this.price}} VNĐ)</li>
                                        {{/each}}
                                 </ul>
                                  <hr>
                                {{#if this.actualCheckInTime}}
                                    <p><strong>Check-in thực tế:</strong> {{DateTime this.actualCheckInTime}}</p>
                                {{/if}}
                                {{#if this.actualCheckOutTime}}
                                    <p><strong>Check-out thực tế:</strong> {{DateTime this.actualCheckOutTime}}</p>
                                {{/if}}
                                <hr>
                                <p><strong>Chi tiết thanh toán:</strong></p>
                                <ul>
                                    <li>Tiền phòng: {{this.soNgay}} đêm × {{money this.roomPrice}} VNĐ = {{money this.totalRoomCost}} VNĐ</li>
                                    <li>Tiền dịch vụ: {{money this.totalServiceCost}} VNĐ</li>
                                    {{#if (gt this.extraAdultSurcharge 0)}} 
                                        <li>Phụ thu thêm người: {{money this.extraAdultSurcharge}} VNĐ</li>
                                    {{/if}}
                                    <li><b>Tổng cộng: {{money this.totalAmount}} VNĐ</b></li>
                                    <li>Đã cọc: {{money this.depositAmount}} VNĐ</li>
                                    <li>Còn lại: <b style="color: red;">{{money this.remainingAmount}} VNĐ</b></li>
                                </ul>
                                </div>
                            </td>
                        </tr>
                    
                        {{else}}
                        <tr>
                            <td colspan="100%" class="text-center">
                            Bạn chưa có phiếu thuê nào.
                           
                            </td>
                        </tr>
                        {{/each}}
                   
                    </tbody>
                </table>
            </div>
            
      </div>
    </div>
  </div>  

 
