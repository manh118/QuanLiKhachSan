<script>
document.addEventListener('DOMContentLoaded', () => {
  const modal = document.querySelector('.js-modal__booking');
  const modalClose = document.querySelector('.modal__booking__close');
  const maHoaDonInput = document.getElementById('maHoaDon'); 

  // Đóng modal
  modalClose.addEventListener('click', () => {
    modal.classList.remove('open');
    document.body.classList.remove('no-scroll');
  });

  // Mở modal và gán dữ liệu
  document.querySelectorAll('.js-TraPhong').forEach(btn => {
     btn.addEventListener('click', async function () {
      modal.classList.add('open');
      document.body.classList.add('no-scroll');

    try {
        maHoaDonInput.value = 'Đang tải...';
        document.getElementById('maHoaDonText').innerText = 'Đang tải...';

        const response = await fetch('/manage/quan_li_hoadon/crud/get-next-id');
        if (!response.ok) {
            throw new Error('Không thể lấy mã hóa đơn');
        }
        const data = await response.json();

        maHoaDonInput.value = data.nextBillId;
        document.getElementById('maHoaDonText').innerText = data.nextBillId;
      } catch (error) {
          console.error(error);
          maHoaDonInput.value = 'Lỗi!';
          document.getElementById('maHoaDonText').innerText = 'Lỗi!';
      }
      // Lấy dữ liệu từ data-*
      const dataset = this.dataset;

        document.getElementById('modalRoom').innerText = dataset.room;
        document.getElementById('fullNameText').innerText = dataset.fullname;
        document.getElementById('phoneText').innerText = dataset.phone;
        document.getElementById('bookingIdForCheckout').value = dataset.id;

        // Điền thông tin tài chính chi tiết
        document.getElementById('modalTotalAmount').innerText = `${dataset.total} VNĐ`;
        document.getElementById('modalDepositAmount').innerText = `${dataset.deposit} VNĐ`;
        document.getElementById('modalRemainingAmount').innerText = `${dataset.remaining} VNĐ`;

        const now = new Date();
        const formattedCheckoutTime =
            `${now.getHours().toString().padStart(2, '0')}:` + 
            `${now.getMinutes().toString().padStart(2, '0')} ` + 
            `${now.getDate().toString().padStart(2, '0')}/` +   
            `${(now.getMonth() + 1).toString().padStart(2, '0')}/` + 
            `${now.getFullYear()}`;                             
        document.getElementById('modalActualCheckoutTime').textContent = formattedCheckoutTime;
    });
  });

  // Modal Check-in logic
  const checkinModal = document.querySelector('.js-modal__checkin');
  if(checkinModal) {
      const closeCheckinBtn = checkinModal.querySelector('.js-close-checkin');
      const formCheckIn = document.getElementById('checkInForm');
      
      closeCheckinBtn.addEventListener('click', () => {
          checkinModal.classList.remove('open');
          document.body.classList.remove('no-scroll');
      });

      document.querySelectorAll('.js-CheckInModalBtn').forEach(btn => {
          btn.addEventListener('click', function() {
              const dataset = this.dataset;
              document.getElementById('checkInRoom').textContent = dataset.room;
              document.getElementById('checkInFullName').value = dataset.fullname;
              document.getElementById('checkInPhone').value = dataset.phone;
              document.getElementById('checkInCCCD').value = ''; // clear previous
              
              // Cài action url vào thẻ form dataset
              formCheckIn.dataset.action = `/manage/quan_li_phieuthue/crud/${dataset.id}/check-in`;
              
              checkinModal.classList.add('open');
              document.body.classList.add('no-scroll');
          });
      });

      document.querySelector('.js-submit-checkin').addEventListener('click', async function() {
          const fullName = document.getElementById('checkInFullName').value.trim();
          const phone = document.getElementById('checkInPhone').value.trim();
          const cccd = document.getElementById('checkInCCCD').value.trim();
          const actionUrl = formCheckIn.dataset.action;

          if(!fullName || !phone || !cccd) {
              alert("Vui lòng điền đầy đủ Họ tên, Số điện thoại và số CCCD/Passport!");
              return;
          }

          try {
              const response = await fetch(actionUrl, {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ fullName, phone, cccd })
              });

              const result = await response.json();
              if(result.success) {
                  alert('Nhận phòng thành công!');
                  window.location.reload();
              } else {
                  alert('Lỗi: ' + result.message);
              }
          } catch (err) {
              console.error(err);
              alert('Có lỗi xảy ra khi thực hiện kết nối API check-in');
          }
      });
  }
});
</script>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const btnLuuTienMat = document.querySelector('.js-checkout-cash');
    const btnTaoQR = document.querySelector('.js-checkout-vnpay');

    // HÀM CHUNG: XỬ LÝ LƯU HÓA ĐƠN TRƯỚC
    async function processInvoice() {
        const billData = {
            idBill: document.getElementById('maHoaDon').value.trim(),
            bookingId: document.getElementById('bookingIdForCheckout').value
        };
        
        if (!billData.bookingId) throw new Error('Không tìm thấy thông tin phiếu thuê.');

        const res = await fetch('/manage/quan_li_hoadon/crud/create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(billData)
        });
        const billRes = await res.json();
        if (billRes.message !== 'success') throw new Error(billRes.message || 'Lưu hóa đơn thất bại!');
        return billData.bookingId;
    }

    // LUỒNG 1: TRẢ TIỀN MẶT (Như cũ)
    btnLuuTienMat.addEventListener('click', async () => {
        try {
            btnLuuTienMat.disabled = true;
            btnLuuTienMat.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> Đang xử lý...';
            
            const bookingId = await processInvoice();

            const checkoutRes = await fetch(`/manage/quan_li_phieuthue/crud/${bookingId}/checkout`, { method: 'POST' }).then(r => r.json());
            if (checkoutRes.message === 'success') {
                alert('Thanh toán và trả phòng thành công!');
                window.location.reload();
            } else {
                throw new Error(checkoutRes.message || 'Cập nhật trạng thái booking thất bại!');
            }
        } catch (err) {
            console.error('Lỗi thanh toán tiền mặt:', err);
            alert('Có lỗi xảy ra: ' + err.message);
            btnLuuTienMat.disabled = false;
            btnLuuTienMat.innerHTML = '<i class="fa-solid fa-print mr-2"></i> Xác nhận thu & Lưu hóa đơn';
        }
    });

    // LUỒNG 2: THANH TOÁN BẰNG VNPAY QR
    btnTaoQR.addEventListener('click', async () => {
        try {
            btnTaoQR.disabled = true;
            btnTaoQR.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> Đang tạo mã...';
            
            // Lấy số tiền còn lại từ DOM (bỏ các ký tự không phải số)
            const remainingText = document.getElementById('modalRemainingAmount').innerText;
            const amountMatch = remainingText.match(/[\d\.]+/);
            if (!amountMatch) throw new Error('Không tính được số tiền còn lại.');
            const amount = parseInt(amountMatch[0].replace(/\./g, ''), 10);
            
            if (amount <= 0) {
                alert('Số tiền còn lại là 0đ, vui lòng chọn hình thức Tiền mặt!');
                btnTaoQR.disabled = false;
                btnTaoQR.innerHTML = '<i class="fa-solid fa-qrcode mr-2"></i> Tạo Mã QR Thanh Toán';
                return;
            }

            // 1. Lưu hóa đơn vào DB trước
            const bookingId = await processInvoice();

            // 2. Tạo link VNPay cho số tiền này
            const res = await fetch('/payment/create_payment_url', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    bookingId: bookingId, 
                    amount: amount,
                    paymentType: 'checkout' // Đánh dấu là thanh toán checkout
                })
            });
            const data = await res.json();
            
            if (data.code === '00') {
                // Mở tab mới chứa cổng VNPay để khách quét
                window.open(data.data, '_blank');
                
                // Hiển thị thông báo hướng dẫn lễ tân
                alert('Đã mở cổng thanh toán VNPay ở tab mới. Hãy xoay màn hình để khách quét mã!\n\nSau khi khách quét xong và báo thành công, hãy tải lại trang này (F5).');
                window.location.reload(); 
            } else {
                throw new Error('Không thể kết nối với VNPAY.');
            }
        } catch (err) {
            console.error('Lỗi tạo VNPay:', err);
            alert('Có lỗi xảy ra: ' + err.message);
            btnTaoQR.disabled = false;
            btnTaoQR.innerHTML = '<i class="fa-solid fa-qrcode mr-2"></i> Tạo Mã QR Thanh Toán';
        }
    });

    const cancelForms = document.querySelectorAll('.form-cancel-booking');
    cancelForms.forEach(form => {
        form.addEventListener('submit', function(event) {
            // Ngăn form submit ngay lập tức
            event.preventDefault();

            // Lấy thông tin để hiển thị xác nhận (tùy chọn)
            const row = form.closest('tr'); // Lấy hàng chứa form
            const roomNumber = row.querySelector('td:nth-child(3)').textContent; // Lấy số phòng từ cột thứ 3
            const customerName = row.querySelector('td:nth-child(4)').textContent; // Lấy tên khách từ cột thứ 4

            // Hiển thị hộp thoại xác nhận
            const confirmed = confirm(`Bạn có chắc chắn muốn hủy phiếu thuê phòng ${roomNumber} của khách ${customerName} không?`);

            // Nếu người dùng xác nhận => Submit form
            if (confirmed) {
                form.submit(); // Gửi request POST với _method=PUT
            }
            // Nếu không xác nhận, không làm gì cả
        });
    });
});
</script>

