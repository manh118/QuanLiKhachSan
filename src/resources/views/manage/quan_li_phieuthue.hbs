        <div class="modal__booking__close js-close-checkin">
            <i class="fa-solid fa-xmark"></i>
        </div>
        <div class="modal__booking__header" style="color: rgb(3, 98, 206);border-bottom: 3px solid rgb(0, 112, 244); padding-bottom: 10px;">Thông Tin Nhận Phòng</div>
        
        <form id="checkInForm" method="POST" action="">
            <div style="padding: 20px 30px;">
                <p style="font-size: 1.6rem; margin-bottom: 20px;"><strong>Phòng: </strong><span id="checkInRoom" style="color: red; font-weight:bold"></span></p>
                
                <div class="modal__booking__body" style="margin-bottom: 15px;">
                    <label class="modal__booking__label" style="color:rgb(0, 112, 244);">Họ tên khách hàng <span style="color:red">*</span></label>
                    <input type="text" class="modal__booking__input" name="fullName" id="checkInFullName" required>
                </div>
                <div class="modal__booking__body" style="margin-bottom: 15px;">
                    <label class="modal__booking__label" style="color:rgb(0, 112, 244);">Số điện thoại <span style="color:red">*</span></label>
                    <input type="text" class="modal__booking__input" name="phone" id="checkInPhone" required>
