<div class="container mt-5 pt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-lg mb-4">
                <div class="card-header bg-hotel-teal text-white border-0 pt-4 pb-3">
                    <h3 class="text-center font-weight-bold mb-0">Tra Cứu Lịch Sử Đặt Phòng</h3>
                    <p class="text-center text-light mt-2 mb-0" style="opacity: 0.8;">Dành cho khách hàng chưa có tài khoản</p>
                </div>
                <div class="card-body px-5 py-4">
                    {{#if error}}
                        <div class="alert alert-danger">{{error}}</div>
                    {{/if}}
                    {{#if success}}
                        <div class="alert alert-success">{{success}}</div>
                    {{/if}}

                    <form action="/account/lookup" method="POST">
                        <div class="form-group mb-4">
                            <label for="bookingId" class="font-weight-bold text-hotel-teal mb-2" style="font-size: 1.1rem;">Mã đặt phòng *</label>
                            <input type="text" class="form-control form-control-lg shadow-sm" id="bookingId" name="bookingId" value="{{bookingId}}" placeholder="VD: 4B07CA" required style="font-size: 1.1rem; padding: 1.5rem 1rem;">
                        </div>
                        <div class="form-group mb-4">
                            <label for="phone" class="font-weight-bold text-hotel-teal mb-2" style="font-size: 1.1rem;">Số điện thoại</label>
                            <input type="text" class="form-control form-control-lg shadow-sm" id="phone" name="phone" value="{{phone}}" placeholder="Nhập số điện thoại đã dùng để đặt phòng" style="font-size: 1.1rem; padding: 1.5rem 1rem;">
                        </div>
                        <div class="form-group mb-4">
                            <label for="email" class="font-weight-bold text-hotel-teal mb-2" style="font-size: 1.1rem;">Email</label>
                            <input type="email" class="form-control form-control-lg shadow-sm" id="email" name="email" value="{{email}}" placeholder="Nhập email nếu có" style="font-size: 1.1rem; padding: 1.5rem 1rem;">
                            <small class="text-muted d-block mt-3" style="font-size: 0.95rem;">Vui lòng nhập <b>Mã đặt phòng</b> VÀ <b>Số điện thoại hoặc Email</b> để bảo mật thông tin.</small>
                        </div>
                        <div class="text-center">
                            <button type="submit" class="btn bg-hotel-teal text-white py-2 px-5 font-weight-bold rounded-pill hover-bg-hotel-teal shadow-sm">
                                <i class="fa-solid fa-magnifying-glass mr-2"></i> TÌM KIẾM
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            {{!-- Hiển thị kết quả --}}
            {{#if bookings}}
            <div class="mt-5">
                <h4 class="mb-4 text-hotel-teal font-weight-bold border-bottom pb-2">Kết Quả Tìm Kiếm ({{bookings.length}} đơn hàng)</h4>
                {{#each bookings}}
                <div class="card shadow-sm border-0 mb-4 rounded-lg overflow-hidden">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <span class="font-weight-bold text-secondary">Mã đơn: #{{this.shortId}}</span>
                        <span class="badge badge-primary px-3 py-2 badge-custom-{{this.bookingStatus}}">{{this.bookingStatus}}</span>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <h5 class="text-hotel-teal font-weight-bold mb-3"><i class="fa-solid fa-bed mr-2"></i>Phòng {{this.roomNumber}}</h5>
                                <p class="mb-1"><i class="fa-regular fa-calendar-check text-muted mr-2"></i><strong>Nhận:</strong> {{Date this.checkInDate}}</p>
                                <p class="mb-1"><i class="fa-regular fa-calendar-xmark text-muted mr-2"></i><strong>Trả:</strong> {{Date this.checkOutDate}}</p>
                                <p class="mb-0"><i class="fa-solid fa-moon text-muted mr-2"></i>{{this.soNgay}} đêm</p>
                            </div>
                            <div class="col-md-6 border-left-md pl-md-4">
                                <p class="mb-1"><i class="fa-solid fa-users text-muted mr-2"></i><strong>Khách:</strong> {{this.nguoiLon}} NL, {{this.treEm}} TE</p>
                                <p class="mb-1"><i class="fa-solid fa-wallet text-muted mr-2"></i><strong>Đã cọc:</strong> <span class="text-success font-weight-bold">{{money this.depositAmount}} đ</span></p>
                                <p class="mb-2"><i class="fa-solid fa-money-bill-wave text-muted mr-2"></i><strong>Tổng tiền:</strong> <span class="text-danger font-weight-bold" style="font-size: 1.2rem;">{{money this.totalAmount}} đ</span></p>
                                
                                {{#if (eq this.bookingStatus 'Pending Deposit')}}
                                    <div class="mt-3">
                                        <button onclick="payNow('{{this._id}}', {{this.depositAmount}})" class="btn btn-sm btn-outline-hotel-teal rounded-pill">
                                            <i class="fa-solid fa-credit-card mr-1"></i> Thanh toán VNPay ngay
                                        </button>
                                    </div>
                                {{/if}}
                            </div>
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>
            {{/if}}

        </div>
    </div>
</div>

<style>
    .bg-hotel-teal { background-color: #20b2aa; }
    .text-hotel-teal { color: #20b2aa; }
    .hover-bg-hotel-teal:hover { background-color: #1a9c95; color: white; }
    .btn-outline-hotel-teal { color: #20b2aa; border-color: #20b2aa; }
    .btn-outline-hotel-teal:hover { background-color: #20b2aa; color: white; }
    .border-left-md { border-left: 1px solid #dee2e6; }
    @media (max-width: 768px) {
        .border-left-md { border-left: none; }
    }
    
    .badge-custom-Pending.Deposit { background-color: #ffc107; color: #333; }
    .badge-custom-Confirmed { background-color: #28a745; color: white; }
    .badge-custom-Checked.In { background-color: #17a2b8; color: white; }
    .badge-custom-Checked.Out { background-color: #6c757d; color: white; }
    .badge-custom-Cancelled { background-color: #dc3545; color: white; }
</style>

<script>
    function payNow(bookingId, amount) {
        fetch('/payment/create_payment_url', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ bookingId, amount })
        })
        .then(res => res.json())
        .then(data => {
            if (data.code === '00') {
                window.location.href = data.data;
            } else {
                alert('Không thể kết nối thanh toán.');
            }
        })
        .catch(err => {
            console.error(err);
            alert('Lỗi tạo thanh toán VNPay.');
        });
    }
</script>
