<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
    /* ============ HERO BANNER ============ */
    .rp-hero {
        position: relative;
        height: 480px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        margin-bottom: 0;
    }
    .rp-hero img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
    }
    .rp-hero::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(0,0,0,0.25), rgba(0,0,0,0.55));
        z-index: 1;
    }
    .rp-hero-content {
        position: relative;
        z-index: 2;
        color: white;
        font-family: 'Montserrat', sans-serif;
        max-width: 700px;
        padding: 0 2rem;
    }
    .rp-hero-content h1 {
        font-size: 3.5rem;
        font-weight: 700;
        letter-spacing: 4px;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        text-shadow: 0 2px 8px rgba(0,0,0,0.3);
    }
    .rp-hero-content p {
        font-size: 1.3rem;
        line-height: 1.8;
        font-weight: 300;
        color: rgba(255,255,255,0.9);
        font-style: italic;
    }

    /* ============ PAGE BODY ============ */
    .rp-page-body {
        font-family: 'Montserrat', sans-serif;
        background-color: #f9fafb;
        padding: 3rem 0 5rem;
    }

    /* ============ FILTER BAR ============ */
    .rp-filter-bar {
        background: white;
        border: none;
        border-radius: 12px;
        padding: 1.2rem 2rem;
        margin-bottom: 3rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    }
    .rp-filter-bar label {
        font-weight: 600;
        font-size: 1.1rem;
        color: #4b5563;
        white-space: nowrap;
        margin-bottom: 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .rp-filter-bar select {
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 0.6rem 1.2rem;
        font-size: 1.1rem;
        color: #1f2937;
        min-width: 240px;
        background: #f9fafb;
        transition: all 0.2s;
    }
    .rp-filter-bar select:focus {
        border-color: #00796B;
        background: white;
        outline: none;
        box-shadow: 0 0 0 3px rgba(0,121,107,0.1);
    }
    .rp-filter-btn {
        background-color: #00796B;
        color: white;
        border: none;
        padding: 0.6rem 2rem;
        border-radius: 8px;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        margin-left: auto;
    }
    .rp-filter-btn:hover {
        background-color: #006055;
        transform: translateY(-1px);
        box-shadow: 0 4px 10px rgba(0,121,107,0.2);
    }

    /* ============ ROOM CARDS GRID ============ */
    .rp-cards-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2.5rem;
        margin-bottom: 3rem;
    }
    @media (max-width: 991px) {
        .rp-cards-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 575px) {
        .rp-cards-grid { grid-template-columns: 1fr; }
    }

    .rp-card {
        background: white;
        border: none;
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 15px rgba(0,0,0,0.04);
        display: flex;
        flex-direction: column;
    }
    .rp-card:hover {
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        transform: translateY(-4px);
    }
    .rp-card-img {
        position: relative;
        height: 240px;
        overflow: hidden;
    }
    .rp-card-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }
    .rp-card:hover .rp-card-img img {
        transform: scale(1.05);
    }
    .rp-card-status {
        position: absolute;
        top: 16px;
        left: 16px;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        z-index: 2;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        backdrop-filter: blur(4px);
    }
    .rp-card-status--available {
        background-color: rgba(209, 250, 229, 0.95);
        color: #065f46;
        border: 1px solid rgba(16, 185, 129, 0.2);
    }
    .rp-card-status--booked {
        background-color: rgba(254, 243, 199, 0.95);
        color: #92400e;
        border: 1px solid rgba(245, 158, 11, 0.2);
    }

    .rp-card-body {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }
    .rp-card-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: #111827;
    }
    .rp-card-price-text {
        color: #00796B;
        font-weight: 700;
    }
    
    .rp-card-primary-amenities {
        display: flex;
        gap: 1.5rem;
    }
    .rp-card-amenity {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #4b5563;
    }
    .rp-card-amenity i {
        font-size: 1.2rem;
        color: #00796B;
        opacity: 0.8;
    }
    .rp-card-amenity span {
        font-size: 0.95rem;
        font-weight: 500;
    }

    .rp-card-secondary-amenities {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        margin-top: auto; /* pushes it to the bottom if content is short */
    }
    .rp-card-secondary-amenities span {
        color: #9ca3af;
        font-size: 1.2rem;
        transition: color 0.2s;
        cursor: default;
    }
    .rp-card-secondary-amenities span:hover {
        color: #4b5563;
    }

    .rp-card-btn {
        display: block;
        width: 100%;
        padding: 0.8rem;
        background-color: #f3f4f6;
        color: #1f2937;
        border: 1px solid transparent;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        text-align: center;
        text-decoration: none;
        transition: all 0.2s;
    }
    .rp-card-btn:hover {
        background-color: #00796B;
        color: white;
        text-decoration: none;
        box-shadow: 0 4px 10px rgba(0,121,107,0.15);
    }

    /* ============ PAGINATION ============ */
    .rp-pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        list-style: none;
        padding: 0;
        margin: 2rem 0 0;
    }
    .rp-pagination li a {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border: 1px solid #d1d5db;
        border-radius: 0.375rem;
        color: #374151;
        font-size: 1.3rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
    }
    .rp-pagination li a:hover {
        background-color: #f3f4f6;
        border-color: #9ca3af;
        text-decoration: none;
    }
    .rp-pagination li.rp-page-active a {
        background-color: #00796B;
        color: white;
        border-color: #00796B;
    }
</style>

<!-- ============ HERO BANNER ============ -->
<section class="rp-hero">
    <img src="{{roomTypes.img}}" alt="{{roomTypes.name}}">
    <div class="rp-hero-content">
        <h1>{{roomTypes.name}}</h1>
        <p>{{roomTypes.description}}</p>
    </div>
</section>

<!-- ============ PAGE BODY ============ -->
<div class="rp-page-body">
    <div class="container" style="max-width: 1400px;">

        <!-- Filter Bar -->
        <form class="rp-filter-bar" method="GET" action="/hangphong/{{roomTypeId}}/rooms">
            <label>Lọc theo:</label>
            <select name="bedType">
                <option value="">Tất cả loại giường</option>
                {{#each bedTypes}}
                    <option value="{{this._id}}" {{#if (eq ../selectedBedType this._id)}}selected{{/if}}>
                        {{this.name}}
                    </option>
                {{/each}}
            </select>
            <button type="submit" class="btn rp-filter-btn">Lọc</button>
        </form>

        <!-- Room Cards Grid -->
        <div class="rp-cards-grid" id="content">
            {{#each Rooms}}
            <div class="rp-card">
                <div class="rp-card-img">
                    <img src="{{this.img}}" alt="Phòng {{this.roomNumber}}">
                    {{#if (eqString this.status 'Đã đặt')}}
                        <span class="rp-card-status rp-card-status--booked">Đã đặt</span>
                    {{else}}
                        <span class="rp-card-status rp-card-status--available">Trống</span>
                    {{/if}}
                </div>
                <div class="rp-card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h3 class="rp-card-title mb-1">Phòng {{this.roomNumber}}</h3>
                            <span class="text-muted" style="font-size: 0.95rem;">Tầng {{this.floor}}</span>
                        </div>
                        <div class="rp-card-price-text text-right">
                            <div style="font-size: 1.3rem; line-height: 1.2;">{{money this.roomType.price}} <span style="font-size: 0.9rem; color: #6b7280; font-weight: 500;">VNĐ</span></div>
                            <div style="font-size: 0.85rem; color: #6b7280; font-weight: 400;">/ Đêm</div>
                        </div>
                    </div>
                    
                    <div class="rp-card-primary-amenities mb-4">
                        <div class="rp-card-amenity">
                            <i class="fa-solid fa-bed"></i>
                            <span>{{this.bedType.name}}</span>
                        </div>
                        <div class="rp-card-amenity">
                            <i class="bx bx-area"></i>
                            <span>{{{m2 this.area}}}</span>
                        </div>
                    </div>
                    
                    <div class="rp-card-secondary-amenities mb-4">
                        {{#each this.roomType.utilities}}
                            <span title="{{this.name}}"><i class="{{this.icon}}"></i></span>
                        {{/each}}
                    </div>

                    <a href="/hangphong/room/{{this.roomNumber}}" class="rp-card-btn">Xem Chi Tiết</a>
                </div>
            </div>
            {{/each}}
        </div>

        <!-- Pagination -->
        <ul class="rp-pagination">
            {{#if (gt currentPage 1)}}
                <li>
                    <a href="?page={{subtract currentPage 1}}{{#if selectedBedType}}&bedType={{selectedBedType}}{{/if}}">
                        <i class="fa-solid fa-angle-left"></i>
                    </a>
                </li>
            {{/if}}

            {{#each (range 1 totalPages)}}
                <li class="{{#if (eq this ../currentPage)}}rp-page-active{{/if}}">
                    <a href="?page={{this}}{{#if ../selectedBedType}}&bedType={{../selectedBedType}}{{/if}}">{{this}}</a>
                </li>
            {{/each}}

            {{#if (lt currentPage totalPages)}}
                <li>
                    <a href="?page={{add currentPage 1}}{{#if selectedBedType}}&bedType={{selectedBedType}}{{/if}}">
                        <i class="fa-solid fa-angle-right"></i>
                    </a>
                </li>
            {{/if}}
        </ul>

    </div>
</div>

<script>
  window.addEventListener('load', () => {
    const url = new URL(window.location.href);
    if (url.searchParams.has('page') || url.searchParams.has('bedType')) {
      const content = document.getElementById('content');
      if (content) {
        content.scrollIntoView({ behavior: 'smooth' });
      }
    }
  });
</script>
